generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String          @id @default(uuid())
  email           String          @unique
  name            String?
  avatar          String?
  role            Role            @default(USER)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  country         String?
  lastName        String?
  organizerStatus OrganizerStatus @default(NONE)
  phone           String?
  isVerified      Boolean         @default(false)
  organizerBio    String?
  stripeAccountId String?         @unique
  chargesEnabled  Boolean         @default(false)
  events               Event[]            @relation("OrganizerEvents")
  favorites            Favorite[]
  orders               Order[]
  coOrganizerEvents    EventCoOrganizer[]
}

model Event {
  id              String       @id @default(uuid())
  title           String
  description     String
  location        String
  coverImage      String?
  genre           String?
  startDate       DateTime
  endDate         DateTime
  isPublished     Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  organizerId      String
  rejectionReason  String?
  status           EventStatus  @default(PENDING)
  checkinToken     String       @unique @default(uuid())
  inviteToken      String?      @unique
  organizer        User         @relation("OrganizerEvents", fields: [organizerId], references: [id], onDelete: Cascade)
  favorites        Favorite[]
  orders           Order[]
  ticketTypes      TicketType[]
  coOrganizers     EventCoOrganizer[]
  startedEmailSent DateTime?
  endedEmailSent   DateTime?
  isModification   Boolean      @default(false)
}

model TicketType {
  id               String   @id @default(uuid())
  name             String
  price            Float
  totalDisponibles Int
  vendidos         Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  eventId          String
  tickets          Ticket[]
  event            Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model Order {
  id              String      @id @default(uuid())
  status          OrderStatus @default(PENDING)
  totalPrice      Float
  stripeSessionId String?     @unique
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  userId          String?
  guestEmail      String?
  guestName       String?
  eventId         String
  event           Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user            User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tickets         Ticket[]
}

model Ticket {
  id           String     @id @default(uuid())
  qrToken      String     @unique @default(uuid())
  isScanned    Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  orderId      String
  ticketTypeId String
  order        Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ticketType   TicketType @relation(fields: [ticketTypeId], references: [id], onDelete: Cascade)
}

model Favorite {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  userId    String
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
}

model EventCoOrganizer {
  id        String   @id @default(uuid())
  eventId   String
  userId    String
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

enum Role {
  USER
  ADMIN
}

enum OrganizerStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum EventStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
}
